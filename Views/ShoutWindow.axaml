<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RemoteShouter.Views.ShoutWindow"
        Title="OpenRemoteShouter"
        Width="820"
        Height="520"
        MinWidth="520"
        MinHeight="360"
        FontFamily="Microsoft YaHei, PingFang SC, Noto Sans CJK SC, WenQuanYi Micro Hei, sans-serif"
        WindowStartupLocation="CenterScreen">
  <Grid x:Name="RootGrid" RowDefinitions="Auto,*">
    <Border x:Name="HeaderBorder" Grid.Row="0" Padding="20,14">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock x:Name="TitleText"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="OpenRemoteShouter"
                   FontWeight="Bold"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="CountdownText"
                   Grid.Column="1"
                   VerticalAlignment="Center"
                   Margin="18,0"
                   FontWeight="Bold" />
        <Button x:Name="CloseButton"
                Grid.Column="2"
                Width="42"
                Height="36"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="CloseButton_OnClick">
          <TextBlock Text="&#x00D7;"
                     FontSize="22"
                     FontWeight="Bold"
                     LineHeight="22"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Button>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="34">
      <Border x:Name="MessageFrame"
              CornerRadius="8"
              Padding="36">
        <ScrollViewer x:Name="MessageScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <Grid x:Name="MessageViewport">
            <TextBlock x:Name="MessageText"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       LineHeight="42" />
          </Grid>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
